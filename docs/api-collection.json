      "url": "{{ _.base_url }}/api/v1/admin/complaints/<COMPLAINT_ID>/resolve",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" },
        { "name": "Content-Type", "value": "application/json" }
