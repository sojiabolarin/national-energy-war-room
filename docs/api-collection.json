{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-05-06",
  "__export_source": "National Energy War Room API Collection v1",
  "resources": [
    {
      "_type": "workspace",
      "_id": "wr-api-ws",
      "name": "National Energy War Room API",
      "description": "Production-grade REST API for the Federal Ministry of Power, Nigeria"
    },
    {
      "_type": "environment",
      "_id": "wr-env-local",
      "name": "Local Development",
      "data": {
        "base_url": "http://localhost:8080",
        "access_token": "",
        "refresh_token": ""
      }
    },
    {
      "_type": "request_group",
      "_id": "grp-health",
      "name": "Health",
      "parentId": "wr-api-ws"
    },
    {
      "_type": "request",
      "_id": "req-health",
      "parentId": "grp-health",
      "name": "Health Check",
      "method": "GET",
      "url": "{{ _.base_url }}/healthz",
      "description": "Returns server health, DB connectivity, and active workers"
    },
    {
      "_type": "request_group",
      "_id": "grp-auth",
      "name": "Auth",
      "parentId": "wr-api-ws"
    },
    {
      "_type": "request",
      "_id": "req-login",
      "parentId": "grp-auth",
      "name": "Login",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/auth/login",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\"email\":\"admin@warroom.gov.ng\",\"password\":\"Admin@WarRoom2025!\"}"
      },
      "description": "Login with email/password. Returns JWT access token (RS256, 15m) and refresh token."
    },
    {
      "_type": "request",
      "_id": "req-register",
      "parentId": "grp-auth",
      "name": "Register (Citizen)",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/auth/register",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\"email\":\"citizen@example.ng\",\"password\":\"Secure@123\",\"fullName\":\"Test Citizen\",\"phone\":\"08012345678\"}"
      }
    },
    {
      "_type": "request",
      "_id": "req-refresh",
      "parentId": "grp-auth",
      "name": "Refresh Token",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/auth/refresh",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\"refreshToken\":\"{{ _.refresh_token }}\"}"
      }
    },
    {
      "_type": "request",
      "_id": "req-me",
      "parentId": "grp-auth",
      "name": "Current User (/me)",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/auth/me",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.access_token }}" }]
    },
    {
      "_type": "request",
      "_id": "req-logout",
      "parentId": "grp-auth",
      "name": "Logout",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/auth/logout",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" },
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\"refreshToken\":\"{{ _.refresh_token }}\"}"
      }
    },
    {
      "_type": "request_group",
      "_id": "grp-complaints-public",
      "name": "Complaints (Public — Tier 1)",
      "parentId": "wr-api-ws"
    },
    {
      "_type": "request",
      "_id": "req-file-complaint",
      "parentId": "grp-complaints-public",
      "name": "File a Complaint",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/complaints",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\"citizenName\":\"Chukwuemeka Obi\",\"citizenPhone\":\"08012345678\",\"citizenEmail\":\"citizen@example.ng\",\"discoId\":\"<DISCO_UUID>\",\"category\":\"ESTIMATED_BILLING\",\"description\":\"I have been receiving estimated bills for 4 months without meter reading.\",\"location\":\"Agege, Lagos\",\"source\":\"WEB\"}"
      },
      "description": "Public endpoint — no auth required. Rate-limited to 60/min per IP. Returns WR-YYYYMMDD-NNNNNN ticket."
    },
    {
      "_type": "request",
      "_id": "req-track-complaint",
      "parentId": "grp-complaints-public",
      "name": "Track Complaint",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/complaints/track/WR-20250106-000001?phoneLast4=5678",
      "description": "Last 4 digits of citizen phone required for verification"
    },
    {
      "_type": "request",
      "_id": "req-satisfaction",
      "parentId": "grp-complaints-public",
      "name": "Submit Satisfaction Score",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/complaints/<COMPLAINT_ID>/satisfaction",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\"token\":\"<SATISFACTION_TOKEN>\",\"score\":4,\"feedback\":\"Issue was resolved after escalation.\"}"
      }
    },
    {
      "_type": "request",
      "_id": "req-whatsapp-webhook-get",
      "parentId": "grp-complaints-public",
      "name": "WhatsApp Webhook Verify (GET)",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/complaints/whatsapp/webhook?hub.mode=subscribe&hub.verify_token=<WHATSAPP_VERIFY_TOKEN>&hub.challenge=123456"
    },
    {
      "_type": "request_group",
